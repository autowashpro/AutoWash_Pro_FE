# ==========================================
# ENVIRONMENT VARIABLES EXAMPLE
# ==========================================
# Copy this file to .env.local and fill in the actual values.
# DO NOT commit .env.local to source control.

# --- API Configuration ---
# Backend .NET 8 dev server (Swagger: http://localhost:5255/swagger)
NEXT_PUBLIC_API_URL=http://localhost:5255/api

# --- Firebase Storage & Auth (autowashpro-47e03) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=autowashpro-47e03.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=autowashpro-47e03
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=autowashpro-47e03.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1057837095099
NEXT_PUBLIC_FIREBASE_APP_ID=1:1057837095099:web:placeholder

# --- Playwright E2E (optional — defaults exist in tests/e2e/*.spec.ts) ---
# Requires BE running with seeded test accounts.
# PLAYWRIGHT_MANAGER_EMAIL=manager1@autowashpro.com
# PLAYWRIGHT_MANAGER_PASSWORD=Admin@123
# PLAYWRIGHT_WASHER_EMAIL=washer1@autowashpro.com
# PLAYWRIGHT_WASHER_PASSWORD=Admin@123
