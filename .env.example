# Copy this file to .env.local and fill in the actual values.
# DO NOT commit .env.local to source control.

# --- API Configuration ---
# Backend .NET 8 dev server (Swagger: http://localhost:5255/swagger)
NEXT_PUBLIC_API_URL=http://localhost:5255/api

